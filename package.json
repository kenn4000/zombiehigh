{
  "name": "zombie-high",
  "version": "1.0.0",
  "description": "Zombie High - multiplayer hex board game",
  "scripts": {
    "dev": "concurrently --names SRV,CLT --prefix-colors cyan,yellow \"tsx watch src/server/server.ts\" \"webpack --watch --config webpack.config.js\"",
    "build:server": "tsc --project tsconfig.server.json",
    "build:client": "webpack --config webpack.config.js",
    "build": "npm run build:server && npm run build:client",
    "clean": "npx rimraf build dist",
    "test": "mocha --require tsx/cjs 'tests/**/*.test.ts'",
    "start": "node build/server/server/server.js"
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "uuid": "^9.0.0",
    "vue": "^2.7.14",
    "vue-template-compiler": "^2.7.14",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/chai": "^4.3.11",
    "@types/express": "^4.17.21",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "chai": "^4.3.10",
    "concurrently": "^9.2.1",
    "css-loader": "^6.8.1",
    "mocha": "^10.2.0",
    "style-loader": "^3.3.3",
    "ts-loader": "^9.5.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vue-loader": "^15.11.1",
    "vue-style-loader": "^4.1.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  }
}